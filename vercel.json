{
  "builds": [
    {
      "src": "artifacts/resume-tools/dist/public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.mjs"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/resume-tools/dist/public/$1"
    }
  ]
}