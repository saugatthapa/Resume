{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/resume-tools build && pnpm --filter @workspace/api-server build",
  "outputDirectory": "artifacts/resume-tools/dist/public",
  "installCommand": "echo skipping default install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/api",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/expire-pro",
      "schedule": "0 0 * * *"
    }
  ]
}