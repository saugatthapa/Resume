# App URL (used in emails, etc.)
APP_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/resume_tools

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Analytics (Plausible - domain only, no protocol)
PLAUSIBLE_DOMAIN=

# Cron secret (generate with: openssl rand -hex 32)
CRON_SECRET=

# Vercel
NODE_ENV=production