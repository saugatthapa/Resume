# ===========================================
# DEVELOPMENT
# ===========================================
PORT=5173
SERVER_PORT=5174
BASE_PATH=/

# ===========================================
# DATABASE (Vercel Postgres)
# ===========================================
# Required. Get from Vercel Dashboard → Storage → your database
DATABASE_URL=postgresql://user:password@host.vercel-postgres.com:5432/default_db?sslmode=require

# ===========================================
# PAYPAL (paypal.com/developer)
# ===========================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# ===========================================
# EMAIL (resend.com)
# ===========================================
# Get API key from Resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ===========================================
# CRON SECURITY
# ===========================================
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ===========================================
# APP URL (your deployed site)
# ===========================================
APP_URL=http://localhost:5173

# ===========================================
# ANALYTICS (plausible.io)
# ===========================================
# Your domain on Plausible (no protocol, no www)
VITE_PLAUSIBLE_DOMAIN=